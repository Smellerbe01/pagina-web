# Ignorar la carpeta de descargas
downloads/*
!downloads/.gitkeep

# Ignorar archivos de configuración de IDEs
.vscode/

# Ignorar archivos de log
*.log

# Ignorar archivos de compilación
build/

# Ignorar el archivo .env
.env

# Ignorar archivos de dependencias
node_modules/

# ignora los cambios en el .json
*settings.json

# Ignorar archivos de entorno virtual
venv/

# Ignorar archivos de caché de Python
__pycache__/

# Ignorar archivos de audio y video
*.mp3
*.webm
*.ogg
*.wav
